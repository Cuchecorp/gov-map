{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@obs/core": ["./packages/core/src/index.ts"],
      "@obs/core/*": ["./packages/core/src/*"],
      "@obs/identity": ["./packages/identity/src/index.ts"],
      "@obs/identity/*": ["./packages/identity/src/*"]
    }
  }
}
