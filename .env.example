# Observatorio del Congreso 360 — plantilla de variables de entorno.
# Copiar a `.env` y rellenar con valores reales. NUNCA commitear `.env`.

# --- LLM / Embeddings ---
GEMINI_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=

# --- Cloudflare R2 (crudo inmutable) ---
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
TOKEN_VALUE_R2=

# --- Supabase ---
SUPABASE_PROJECT_ID=
SUPABASE_SECRET_KEY=
SUPABASE_API_URL=
# Alias canonico de SUPABASE_API_URL (mismo valor). Lo leen app/lib/supabase-admin.ts,
# app/lib/web-reader-jwt.ts y varios CLIs como `SUPABASE_URL ?? SUPABASE_API_URL`.
SUPABASE_URL=
# Clave publica (anon) del proyecto Supabase — SAFE para el navegador, NO bypasa RLS.
# La lee app/lib/supabase.ts (createServerSupabase usa el anon key como apikey de Kong).
SUPABASE_ANON_KEY=
# URL directa de Postgres (NO la API REST) — la usan los CLIs de lobby/dinero/probidad
# para DDL/bulk. Dashboard -> Settings -> Database. Formato:
# postgresql://postgres:<password>@<host>:5432/postgres
SUPABASE_DB_URL=
# JWT secret del proyecto para firmar el token web_reader (LOCKDOWN-03).
# Obtener en Dashboard -> Settings -> API -> JWT Settings -> JWT Secret.
# NO es SUPABASE_SECRET_KEY (sb_secret_...): esa es la service key (bypasa RLS).
SUPABASE_JWT_SECRET=

# --- Ingest worker ---
# CR-01/CR-04: secreto DEDICADO de invocacion del worker, separado del
# service_role. El dispatcher SQL lo envia como `Authorization: Bearer <secret>`
# y el worker lo valida (constant-time). NUNCA reutilizar el service_role aqui.
# En Postgres se setea como secreto de vault `ingest_worker_secret` o
# `alter database postgres set app.settings.ingest_worker_secret = '<secret>'`.
INGEST_WORKER_SECRET=
# CR-03 (solo dev/CI): hosts extra permitidos sobre http para E2E (coma-separados),
# p.ej. `dummy.local`. En produccion dejar VACIO (allowlist = solo https gob).
INGEST_ALLOW_TEST_HOSTS=
# WR-05 (CI backfill): numero de iteraciones del backfill (entero 1..1000).
BACKFILL_ITERATIONS=1

# Mapeo canonico de secretos (IN-03):
#   worker (Deno.env)        ->  Postgres (migracion 0003)
#   SUPABASE_API_URL         ->  app.settings.project_url / vault 'project_url'
#   SUPABASE_SECRET_KEY      ->  service_role (solo cliente supabase-js server-side)
#   INGEST_WORKER_SECRET     ->  app.settings.ingest_worker_secret / vault 'ingest_worker_secret'

# --- Gate de exposicion MONEY (Ley 21.719, Phase 13) ---
# Candado B (presentacion) del doble candado de exposicion MONEY (LEGAL-01, D-25).
# Default OFF. NO es un secreto: es un booleano de feature.
# Encender SOLO tras sign-off legal humano (signoff: approved en
# docs/legal/13-LEGAL-DOSSIER.md; deuda de operador F13). Server-only, leido por
# app/lib/money-gate.ts; solo el literal "true" lo enciende (cualquier otro valor
# => false, fail-closed). NUNCA prefijar NEXT_PUBLIC_ (no debe llegar al bundle del
# navegador). No anadir canal Postgres (app.settings.money_public_enabled) aqui: el
# consumidor declarado es Next.js server-side; Phases 14-16 lo agregaran si un RPC
# llega a consultar el flag.
MONEY_PUBLIC_ENABLED=false

# --- Gate de la superficie ADMIN de revision de terceros (ENT-04, Phase 35) ---
# Habilita la ruta interna protegida /admin/revisar-entidades (cola de adjudicacion
# humana de entidad_tercero). Default OFF (fail-closed): solo el literal "true" la
# enciende; con OFF la ruta 404 sin filtrar la cola PII. Server-only, leido por
# app/lib/admin-gate.ts. NO es superficie publica. NUNCA prefijar NEXT_PUBLIC_.
ADMIN_REVISION_ENABLED=false

# Service-role key del Supabase (NO la anon): la cola revision_entidad y la maestra
# entidad_tercero son deny-by-default a anon; la superficie admin las lee/escribe con
# la SERVICE key vía app/lib/supabase-admin.ts. SECRETO de operador. Server-only,
# JAMAS al bundle del navegador. NUNCA prefijar NEXT_PUBLIC_.
SUPABASE_SERVICE_KEY=

# --- ChileCompra / Mercado Publico (conector @obs/dinero, Phase 14) ---
# Ticket de la API de Mercado Publico (api.mercadopublico.cl). Secreto de OPERADOR:
# se obtiene con Clave Unica (formulario), limite ~10.000 solicitudes/dia/ticket.
# Server-only, leido SOLO de env por @obs/dinero (nunca por argv, nunca al cliente,
# jamas interpolado en mensajes de error). SIN este ticket, el CLI de @obs/dinero
# degrada a dry-run (InMemory) y NUNCA fabrica contratos. NO prefijar NEXT_PUBLIC_.
MERCADOPUBLICO_TICKET=

# --- SERVEL / financiamiento de campana (conector @obs/dinero, Phase 15) ---
# Bucket de Supabase Storage donde se versiona el crudo .xlsx de SERVEL (clave
# servel/<eleccion>/<fecha>/<hash>.xlsx). El OPERADOR crea el bucket privado
# (checkpoint). Defaultable en codigo a "crudo-servel" si se deja vacio. La fuente
# SERVEL es PUBLICA (Azure Blob, GET anonimo) -> NO requiere credencial propia.
# El crudo va a Supabase Storage porque R2 devuelve 401 (deuda de operador). El
# enlace del candidato por NOMBRE usa el provider LLM del pipeline (@obs/adjudication),
# cuyas credenciales (GEMINI/MINIMAX/DEEPSEEK) ya estan arriba — NO duplicarlas.
SERVEL_CRUDO_BUCKET=crudo-servel

# --- Frontend (Next.js / Cloudflare Pages) ---
# Controla <meta name="robots"> en app/app/layout.tsx: el literal "true" => indexable;
# cualquier otro valor (o ausente) => noindex. Server-only, NO prefijar NEXT_PUBLIC_.
PUBLIC_INDEXABLE=false

# --- Dev local (Supabase CLI: `supabase start`) ---
# Override opcional para apuntar los CLIs de ingesta al stack Supabase local en vez de
# PROD. Si se setean, varios CLIs los prefieren sobre SUPABASE_API_URL / SUPABASE_SERVICE_KEY.
# Dejar VACIO en operacion normal (los CLIs apuntan a PROD via las vars de arriba).
SUPABASE_LOCAL_URL=
SUPABASE_LOCAL_SERVICE_KEY=
